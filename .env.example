# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Authentication — two options, pick one:
#
# Option 1: API key (standard, works everywhere)
#   Set ANTHROPIC_API_KEY and the SDK picks it up automatically.
#
# Option 2: Claude Code session token (no key needed)
#   Log in via `claude login` in your terminal. The SDK detects the active
#   Claude Code session and uses it — no env var required.
#   Leave ANTHROPIC_API_KEY unset or commented out when using this option.

ANTHROPIC_API_KEY=your-api-key-here

# ── Email (EmailAgent) ────────────────────────────────────────────────
# Required only if you use the EmailAgent to send reports.
#
# Gmail setup:
#   1. Enable 2-factor authentication on your Google account.
#   2. Go to myaccount.google.com/apppasswords and generate an App Password.
#   3. Use that 16-character App Password as SMTP_PASSWORD (not your Gmail password).
#   4. SMTP_HOST and SMTP_PORT are fixed for Gmail — do not change them.
#
# Other providers:
#   Outlook/Hotmail : SMTP_HOST=smtp-mail.outlook.com  SMTP_PORT=587
#   Yahoo           : SMTP_HOST=smtp.mail.yahoo.com    SMTP_PORT=587
#   Custom / SES    : set host, port, user, and password from your provider

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
