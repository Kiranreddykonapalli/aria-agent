# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Authentication — two options, pick one:
#
# Option 1: API key (standard, works everywhere)
#   Set ANTHROPIC_API_KEY and the SDK picks it up automatically.
#
# Option 2: Claude Code session token (no key needed)
#   Log in via `claude login` in your terminal. The SDK detects the active
#   Claude Code session and uses it — no env var required.
#   Leave ANTHROPIC_API_KEY unset or commented out when using this option.

ANTHROPIC_API_KEY=your-api-key-here
